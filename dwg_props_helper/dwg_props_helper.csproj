<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>dwg_props_helper</AssemblyName>
    <RootNamespace>DwgPropsHelper</RootNamespace>
    <!-- Standalone publish: nema potrebe za instaliranim .NET-om -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>
  <ItemGroup>
    <!-- ACadSharp: MIT-licensed .NET library za nativno čitanje/pisanje DWG/DXF -->
    <PackageReference Include="ACadSharp" Version="3.5.7" />
  </ItemGroup>
</Project>
